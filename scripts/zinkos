#!/bin/bash
#
# zinkos вЂ” CLI tool for managing the Zinkos audio driver
#

set -euo pipefail

# в”Ђв”Ђ Colors в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
AMBER='\033[38;5;172m'
BROWN='\033[38;5;130m'
DIM='\033[38;5;137m'
BOLD='\033[1m'
RESET='\033[0m'
RED='\033[38;5;160m'
GREEN='\033[38;5;107m'

# в”Ђв”Ђ Constants в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
PLIST_PATH="/Library/Preferences/com.zinkos.driver"
DRIVER_PATH="/Library/Audio/Plug-Ins/HAL/Zinkos.driver"
SCRIPT_PATH="$(cd "$(dirname "$0")" && pwd)/$(basename "$0")"
# Follow symlink to real location
if [ -L "$SCRIPT_PATH" ]; then
    SCRIPT_PATH="$(readlink "$SCRIPT_PATH")"
elif [ -L "$0" ]; then
    SCRIPT_PATH="$(readlink "$0")"
fi
SCRIPT_REAL_DIR="$(cd "$(dirname "$SCRIPT_PATH")" && pwd)"
REPO_DIR="$(cd "$SCRIPT_REAL_DIR/.." && pwd)"

# Read version: try repo VERSION file first, then pkg-installed sidecar
if [ -f "$REPO_DIR/VERSION" ]; then
    VERSION=$(tr -d '[:space:]' < "$REPO_DIR/VERSION")
elif [ -f "$SCRIPT_REAL_DIR/.zinkos-version" ]; then
    VERSION=$(tr -d '[:space:]' < "$SCRIPT_REAL_DIR/.zinkos-version")
else
    VERSION="unknown"
fi

# в”Ђв”Ђ Helpers в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ

print_logo() {
    local ver="v${VERSION}"
    local content="     Wi-Fi Audio Streaming  ${ver}"
    local width=35  # inner width between в•‘ and в•‘
    local pad=$(( width - ${#content} ))
    local spaces=""
    for (( i=0; i<pad; i++ )); do spaces+=" "; done

    echo -e "${BOLD}${AMBER}"
    echo '  в•”в•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•—'
    echo '  в•‘         Z I N K O S               в•‘'
    echo -e "  в•‘${content}${DIM}${spaces}${BOLD}${AMBER}в•‘"
    echo '  в•љв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ќ'
    echo -e "${RESET}"
}

info() {
    echo -e "  ${AMBER}в–ё${RESET} $1"
}

success() {
    echo -e "  ${GREEN}вњ“${RESET} $1"
}

error() {
    echo -e "  ${RED}вњ—${RESET} $1" >&2
}

label() {
    printf "  ${BROWN}%-18s${RESET} " "$1"
    echo -e "$2"
}

# Read a plist value, return empty string if not set
plist_read() {
    defaults read "$PLIST_PATH" "$1" 2>/dev/null || echo ""
}

# в”Ђв”Ђ Commands в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ

cmd_status() {
    print_logo

    # Driver installation
    local driver_status
    if [ -d "$DRIVER_PATH" ]; then
        driver_status="${GREEN}installed${RESET}"
    else
        driver_status="${RED}not installed${RESET}"
    fi

    # coreaudiod status
    local coreaudiod_status
    local pid
    pid=$(pgrep -x coreaudiod 2>/dev/null || echo "")
    if [ -n "$pid" ]; then
        coreaudiod_status="${GREEN}running${RESET} (PID $pid)"
    else
        coreaudiod_status="${RED}not running${RESET}"
    fi

    # Config values
    local ip port latency
    ip=$(plist_read "ReceiverIP")
    port=$(plist_read "ReceiverPort")
    latency=$(plist_read "LatencyOffsetMs")

    echo -e "  ${BOLD}${AMBER}в”Ђв”Ђ Status в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ${RESET}"
    echo ""
    label "Driver:" "$(echo -e "$driver_status")"
    label "coreaudiod:" "$(echo -e "$coreaudiod_status")"
    echo ""
    echo -e "  ${BOLD}${AMBER}в”Ђв”Ђ Config в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ${RESET}"
    echo ""
    label "Receiver IP:" "${ip:-${DIM}(not set вЂ” default 192.168.1.87)${RESET}}"
    label "Receiver Port:" "${port:-${DIM}(not set вЂ” default 4010)${RESET}}"
    label "Latency Offset:" "${latency:+${latency} ms}${latency:-${DIM}(not set вЂ” default 0 ms)${RESET}}"
    echo ""
}

cmd_set() {
    local key="$1"
    local value="$2"

    case "$key" in
        ip)
            # Basic IP format check
            if ! echo "$value" | grep -qE '^[0-9]+\.[0-9]+\.[0-9]+\.[0-9]+$'; then
                error "Invalid IP address: $value"
                exit 1
            fi
            sudo defaults write "$PLIST_PATH" ReceiverIP -string "$value"
            success "Receiver IP set to ${BOLD}$value${RESET}"
            ;;
        port)
            if ! echo "$value" | grep -qE '^[0-9]+$' || [ "$value" -lt 1 ] || [ "$value" -gt 65535 ]; then
                error "Invalid port: $value (must be 1вЂ“65535)"
                exit 1
            fi
            sudo defaults write "$PLIST_PATH" ReceiverPort -int "$value"
            success "Receiver port set to ${BOLD}$value${RESET}"
            ;;
        latency)
            if ! echo "$value" | grep -qE '^[0-9]+$'; then
                error "Invalid latency: $value (must be a non-negative integer in ms)"
                exit 1
            fi
            sudo defaults write "$PLIST_PATH" LatencyOffsetMs -int "$value"
            success "Latency offset set to ${BOLD}${value} ms${RESET}"
            ;;
        *)
            error "Unknown setting: $key"
            echo -e "  ${DIM}Valid settings: ip, port, latency${RESET}"
            exit 1
            ;;
    esac

    echo -e "  ${DIM}Run ${AMBER}zinkos reload${DIM} to apply changes.${RESET}"
}

cmd_reload() {
    info "Restarting coreaudiod..."
    sudo killall coreaudiod
    sleep 2

    local pid
    pid=$(pgrep -x coreaudiod 2>/dev/null || echo "")
    if [ -n "$pid" ]; then
        success "coreaudiod restarted (PID $pid)"
    else
        error "coreaudiod did not restart"
        exit 1
    fi
}

cmd_rebuild() {
    info "Rebuilding and reloading driver..."
    "$REPO_DIR/scripts/reload.sh" "${REPO_DIR}/build"
}

cmd_version() {
    echo "$VERSION"
}

cmd_help() {
    print_logo
    echo -e "  ${BOLD}${AMBER}Usage:${RESET}  zinkos <command>"
    echo ""
    echo -e "  ${BOLD}${AMBER}Commands:${RESET}"
    echo -e "    ${BROWN}status${RESET}              Show current config and driver status"
    echo -e "    ${BROWN}set ip${RESET} <IP>         Set receiver IP address"
    echo -e "    ${BROWN}set port${RESET} <PORT>     Set receiver UDP port"
    echo -e "    ${BROWN}set latency${RESET} <MS>    Set latency offset (ms)"
    echo -e "    ${BROWN}rebuild${RESET}             Build, validate, install, and reload driver"
    echo -e "    ${BROWN}reload${RESET}              Restart coreaudiod to apply changes"
    echo -e "    ${BROWN}version${RESET}             Show version"
    echo -e "    ${BROWN}help${RESET}                Show this help"
    echo ""
}

# в”Ђв”Ђ Main в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ

case "${1:-}" in
    status)
        cmd_status
        ;;
    set)
        if [ -z "${2:-}" ] || [ -z "${3:-}" ]; then
            error "Usage: zinkos set <ip|port|latency> <value>"
            exit 1
        fi
        cmd_set "$2" "$3"
        ;;
    rebuild)
        cmd_rebuild
        ;;
    reload)
        cmd_reload
        ;;
    version|--version|-V)
        cmd_version
        ;;
    help|--help|-h)
        cmd_help
        ;;
    "")
        cmd_help
        ;;
    *)
        error "Unknown command: $1"
        echo -e "  ${DIM}Run ${AMBER}zinkos help${DIM} for usage.${RESET}"
        exit 1
        ;;
esac
